<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><% if (page.title) { %><%= page.title %> · <% } %><%= config.title %></title>
  <meta name="description" content="<%= config.description || config.title %>">
  <link rel="stylesheet" href="<%- url_for('/css/echo.css') %>">
</head>
<body class="<% if (is_home()) { %>home-template<% } else { %>inner-template<% } %>">
  <div class="mask mask-top" aria-hidden="true"></div>
  <div class="mask mask-bottom" aria-hidden="true"></div>
  <div class="mask mask-left" aria-hidden="true"></div>
  <div class="mask mask-right" aria-hidden="true"></div>

  <div class="mobile-red-header">
    <a class="mobile-brand" href="<%- url_for('/') %>"><%= config.title %></a>
    <button class="mobile-menu-btn" onclick="document.querySelector('.mobile-nav').classList.toggle('open')" aria-label="打开导航">☰</button>
  </div>
  <nav class="mobile-nav" aria-label="移动端导航">
    <a href="<%- url_for('/') %>">首页</a>
    <a href="<%- url_for('/archives/') %>">归档</a>
    <a href="<%- url_for('/categories/文章/') %>">文章</a>
    <a href="<%- url_for('/categories/摄影/') %>">摄影</a>
    <a href="<%- url_for('/categories/乒乓球/') %>">乒乓球</a>
    <a href="<%- url_for('/categories/AI/') %>">AI</a>
  </nav>

  <div class="page-shell">
    <div class="notice ptn" role="note">
      <strong>Now</strong>
      <span><%= config.description || '把想法慢慢写下来。' %></span>
      <span><%= date(new Date(), 'YYYY-MM-DD') %></span>
    </div>

    <% if (!is_home()) { %>
      <header class="masthead masthead-compact">
        <div>
          <div class="brand-line">
            <a class="logo" href="<%- url_for('/') %>"><%= config.title %></a>
            <span class="tagline">Personal Journal</span>
          </div>
          <h1><%= page.title || config.title %></h1>
          <p class="intro"><%= config.description || '一个安静、清爽、适合长期维护的个人博客。' %></p>
        </div>
        <nav class="nav-box" aria-label="主导航">
          <div class="nav-title">Directory</div>
          <div class="nav-list">
            <a href="<%- url_for('/') %>"><span>首页</span><span>Home</span></a>
            <a href="<%- url_for('/archives/') %>"<% if (is_archive()) { %> aria-current="page"<% } %>><span>归档</span><span>Archive</span></a>
            <a href="<%- url_for('/categories/文章/') %>"><span>文章</span><span>Writing</span></a>
            <a href="<%- url_for('/categories/摄影/') %>"><span>摄影</span><span>Photo</span></a>
            <a href="<%- url_for('/categories/AI/') %>"><span>AI</span><span>AI</span></a>
          </div>
        </nav>
      </header>
    <% } %>

    <%- body %>

    <footer class="footer">
      <span>© <%= new Date().getFullYear() %> <%= config.author || config.title %> · Built with <a href="https://hexo.io/" rel="noreferrer">Hexo</a></span>
      <span>Back to life, one note at a time.</span>
    </footer>
  </div>
</body>
</html>
