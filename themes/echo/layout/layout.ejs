<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><% if (page.title) { %><%= page.title %> · <% } %><%= config.title %></title>
  <meta name="description" content="<%= config.description || config.title %>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="stylesheet" href="<%- url_for('/css/echo.css') %>">
</head>
<body>
  <div class="site-shell">
    <header class="site-header">
      <nav class="nav-bar">
        <a class="brand" href="<%- url_for('/') %>"><span class="brand-mark">E</span><span><%= config.title %></span></a>
        <div class="nav-links">
          <a href="<%- url_for('/') %>">首页</a>
          <a href="<%- url_for('/archives/') %>">归档</a>
        </div>
      </nav>
      <section class="hero">
        <p class="eyebrow">Personal Journal</p>
        <h1>把想法慢慢写下来。</h1>
        <p class="hero-copy"><%= config.description || '一个安静、清爽、适合长期维护的个人博客。' %></p>
      </section>
    </header>
    <main class="content">
      <%- body %>
    </main>
    <footer class="site-footer">
      <span>© <%= new Date().getFullYear() %> <%= config.author || config.title %></span>
      <span>Built with Hexo</span>
    </footer>
  </div>
</body>
</html>
