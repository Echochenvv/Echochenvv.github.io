<header class="masthead" data-screen-label="01 Home">
  <div>
    <div class="brand-line">
      <a class="logo" href="<%- url_for('/') %>"><%= config.title %></a>
      <span class="tagline">Personal Journal</span>
    </div>
    <h1>back to life</h1>
    <p class="intro"><%= config.description || '把想法慢慢写下来。' %></p>
  </div>

  <nav class="nav-box" aria-label="主导航">
    <div class="nav-title">Directory</div>
    <div class="nav-list">
      <a href="<%- url_for('/') %>" aria-current="page"><span>首页</span><span>Home</span></a>
      <a href="<%- url_for('/archives/') %>"><span>归档</span><span>Archive</span></a>
      <a href="<%- url_for('/categories/文章/') %>"><span>文章</span><span>Writing</span></a>
      <a href="<%- url_for('/categories/摄影/') %>"><span>摄影</span><span>Photo</span></a>
      <a href="<%- url_for('/categories/乒乓球/') %>"><span>乒乓球</span><span>Ping Pong</span></a>
      <a href="<%- url_for('/categories/人工智能/') %>"><span>人工智能</span><span>AI</span></a>
    </div>
  </nav>
</header>

<div class="content-grid">
  <main id="latest">
    <div class="section-label">
      <span>All Modules</span>
      <span><%= site.posts.length %> 篇文章</span>
    </div>

    <% if (site.posts.length) { %>
      <% var catOrder = ['人工智能', '文章', '摄影', '乒乓球']; %>
      <% var globalIndex = 0; %>
      <% catOrder.forEach(function(catName) { %>
        <% var cat = site.categories.findOne({name: catName}); %>
        <% if (cat && cat.posts.length) { %>
          <section class="category-module">
            <div class="section-label cat-header">
              <a href="<%- url_for(cat.path) %>"><span><%= catName %></span></a>
              <span><%= cat.posts.length %> 篇 · <a href="<%- url_for(cat.path) %>">全部 →</a></span>
            </div>
            <% cat.posts.sort('date', -1).each(function(post){ %>
              <% globalIndex += 1; %>
              <article class="feed-item" data-number="<%= globalIndex %>">
                <time class="feed-date" datetime="<%= post.date.toISOString() %>"><%= date(post.date, 'MM/DD') %></time>
                <div>
                  <h3><a href="<%- url_for(post.path) %>"><%= post.title || '未命名文章' %></a></h3>
                  <p><%- post.excerpt || strip_html(post.content).slice(0, 90) + '…' %></p>
                </div>
              </article>
            <% }) %>
          </section>
        <% } %>
      <% }) %>
    <% } else { %>
      <article class="empty-card pattern-panel">
        <h2>新博客已就绪</h2>
        <p>第一篇文章还在路上。后续内容会从这里开始更新。</p>
      </article>
    <% } %>
  </main>

  <aside class="rail" id="about" aria-label="侧栏信息">
    <section class="panel">
      <div class="panel-title"><span>About</span><span>!</span></div>
      <div class="panel-body">
        <p><%= config.description || 'Echochenvv 的个人博客。关键词先别太满：生活、想法、更新、慢慢写。' %></p>
      </div>
    </section>

    <section class="panel">
      <div class="panel-title"><span>Archive</span><span>№</span></div>
      <div class="panel-body">
        <ul class="mini-list">
          <% var years = {}; site.posts.each(function(post){ years[date(post.date, 'YYYY')] = true; }); %>
          <% Object.keys(years).sort().reverse().slice(0, 4).forEach(function(year){ %>
            <li class="has-ghost-number" data-number="<%= year.slice(2) %>">
              <b><%= year %></b><span>查看这一年的记录。</span>
            </li>
          <% }) %>
          <% if (!Object.keys(years).length) { %>
            <li><b>Archive</b><span>内容正在路上。</span></li>
          <% } %>
        </ul>
      </div>
    </section>

    <section class="panel submit-box pattern-panel">
      <div class="panel-title"><span>Subscribe</span><span>RSS</span></div>
      <div class="panel-body">
        <p>保留一个轻量订阅区，借鉴 anyway.fm 的工具侧栏感觉，但只放博客真正需要的入口。</p>
        <div class="input-row">
          <input value="echochenvv.github.io" aria-label="站点地址" readonly>
          <a class="copy-button" href="<%- url_for('/atom.xml') %>">RSS</a>
        </div>
      </div>
    </section>
  </aside>
</div>
